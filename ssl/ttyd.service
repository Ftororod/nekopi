[Unit]
Description=NekoPi — Web Terminal (ttyd) with SSL
After=network.target

[Service]
Type=simple
User=nekopi
ExecStart=/usr/bin/ttyd --port 7681 --interface 0.0.0.0 --credential nekopi:nekopi2024 --ssl --ssl-cert /opt/nekopi/ssl/cert.pem --ssl-key /opt/nekopi/ssl/key.pem bash
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
